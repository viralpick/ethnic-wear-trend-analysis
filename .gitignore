# Pipeline outputs
outputs/
# Vision LLM 응답 캐시 (Phase 2). outputs/ 이미 제외되지만 명시 — BE 연동 시
# AzureBlobCache 로 이관 예정, 그 전까진 로컬 전용.
outputs/llm_cache/

# Secrets / local config overrides
.env
.env.local
configs/local.override.yaml

# Roadmap 은 memory 로 이관됐고 docs/roadmap.md 는 절대 경로 symlink (로컬 전용).
# 다른 머신에서는 memory 디렉토리 자체가 없으므로 깨진 symlink 가 된다 — git 관리 X.
docs/roadmap.md

# IDE
.idea/
.vscode/
*.swp

# Claude Code per-project 로컬 권한 (per-user). 팀 공유 hook 은 .claude/settings.json 으로.
.claude/settings.local.json
# Claude Code /loop runtime lock — 세션별 생성, 공유 불필요
.claude/scheduled_tasks.lock

# Serena MCP 로컬 캐시 (심볼 인덱스). 로컬 전용, 팀 공유 X.
.serena/

# OS
.DS_Store
__MACOSX/

# Ultralytics / HF Hub 가 런타임에 CWD / ~/.cache 로 다운받는 모델 가중치.
# vision extras 설치 + Pipeline B 실행 후 생기는 파일. 레포에 커밋 금지 (큰 바이너리).
*.pt
yolov*.pt

# Sample images — 실 IG 이미지 drop (public 레포 저작권/PII 리스크 회피).
# 큐레이션된 샘플을 올리려면 별도 경로에 명시적으로 추가.
sample_data/image/
# Blob 다운로드 캐시 (scripts/download_blobs.py 산출). 실 IG 이미지 다수라 public 금지.
sample_data/image_cache/

# 크롤러 DB 에서 export 한 실 데이터 샘플 (TSV) + Azure Blob SAS URL 리스트 (TXT).
# 실 계정/캡션/이미지 경로/SAS 경로 포함 — public 레포 금지. JSON 고정 fixture 는 허용.
sample_data/*.tsv
sample_data/*.txt
